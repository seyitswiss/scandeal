generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Business {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  phone           String?
  website         String?
  category        String?
  subCategory     String?
  logoUrl         String?
  // Location
  address         String?
  postalCode      String?
  googleMapsUrl   String?
  googleReviewUrl String?
  // Social
  instagram       String?
  linkedin        String?
  tripadvisor     String?
  whatsapp        String?
  email           String?
  tiktok          String?
  facebook        String?
  // Custom links (JSON string)
  customLinks     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  deals           Deal[]
  stats           BusinessStat[]
}

model Deal {
  id           String    @id @default(cuid())
  title        String
  description  String?
  discountText String?
  highlight    String?
  image        String?
  category     String?
  subCategory  String?
  isPremium    Boolean   @default(false)
  isActive     Boolean   @default(true)
  startDate    DateTime?
  endDate      DateTime?
  businessId   String
  business     Business  @relation(fields: [businessId], references: [id], onDelete: Cascade)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  stats        DealStat[]
}

model BusinessStat {
  id         String   @id @default(cuid())
  businessId String
  business   Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  type       String   // "profile_view", "link_click", "ai_usage"
  source     String?  // "qr", "instagram", "google", "deal_generator", etc.
  createdAt  DateTime @default(now())
}

model DealStat {
  id         String   @id @default(cuid())
  dealId     String
  deal       Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  businessId String
  type       String   // "view", "click"
  createdAt  DateTime @default(now())
}